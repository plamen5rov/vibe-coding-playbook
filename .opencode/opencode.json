{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (Local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1",
        "apiKey": "not-needed"
      },
      "models": {
        "qwen/qwen3.5-9b": {
          "name": "Qwen3.5 9B (local)"
        }
      }
    }
  },
  "agent": {
    "build": {
      "color": "#7BF707"
    },
    "plan": {
      "color": "#F2AF07"
    }
  },
  "permission": {
    "read": "allow",
    "grep": "allow",
    "edit": "ask",
    "write": "ask",
    "bash": "allow",
    "webfetch": "ask",
    "websearch": "allow",
    "glob": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "question": "allow",
    "process": "ask"
  },
  "instructions": ["AGENTS.md", "AI.md", "docs/*.md"]
}
